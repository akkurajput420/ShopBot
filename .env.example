# .env.example
# SECURITY WARNING: Never commit real credentials to version control!
# Copy this file to .env and fill with actual values

# === TELEGRAM CONFIGURATION ===
# @BotFather se mila hua token yahan daalein
TOKEN=8572399257:AAFfPPM507FS9kA5xcCvDjxN56mc0le7m-Y
# Aapka numerical Telegram ID
OWNER_ID=8502394982

# === PAYMENT CONFIGURATION (INR ONLY) ===
# Currency ko INR set kar diya hai
PAY_CURRENCY=INR

# Telegram Id (Agar use karna hai toh value badlein, varna 35 rakhein)
TG_PER_ID=35

# Payment Limits (Minimum ₹10, Maximum ₹50,000)
MIN_AMOUNT=10
MAX_AMOUNT=50000

# Payment Timeout (30 minutes)
PAYMENT_TIME=1800

# Referral system (Percentage % mein, 0 matlab band)
REFERRAL_PERCENT=5

# === LINKS & UI CONFIGURATION ===
CHANNEL_URL=https://t.me/your_channel
CHANNEL_ID=
HELPER_ID=8502394982
RULES="1. No refunds\n2. Respect support\n3. Use Indian Payment methods only"

# === LOCALIZATION & LOGGING ===
# Indian users ke liye English (en) ya Russian (ru) choose karein
BOT_LOCALE=en
DEBUG=0
LOG_TO_STDOUT=1
LOG_TO_FILE=1
REVIEWS_ENABLED=1

# === DATABASE CONFIGURATION ===
# Agar aap local pe run kar rahe hain toh localhost hi rehne dein
POSTGRES_DB=telegram_shop
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_strong_password
POSTGRES_HOST=localhost
DB_PORT=5432

# === REDIS CONFIGURATION ===
# Performance ke liye ise 1 rakhein, agar Redis nahi hai toh 0 kar dein
REDIS_ENABLED=0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# === WEB ADMIN PANEL ===
ADMIN_HOST=0.0.0.0
ADMIN_PORT=9090
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin_secret_password
SECRET_KEY=generate_a_random_string_here

# === WEBHOOK MODE ===
# Polling ke liye ise 0 hi rehne dein (Simple aur best hai)
WEBHOOK_ENABLED=0
